{
  "name": "klariti-os",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "pnpm --filter @klariti/database drizzle:generate",
    "db:migrate": "pnpm --filter @klariti/database drizzle:migrate",
    "db:push": "pnpm --filter @klariti/database drizzle:push",
    "studio": "pnpm --filter @klariti/database studio",
    "generate": "turbo run generate",
    "fetch-spec": "pnpm --filter @klariti/api-client fetch-spec",
    "generate:api-client": "pnpm --filter @klariti/api-client generate:full"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.1",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "api"
  ]
}
