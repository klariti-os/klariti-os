DATABASE_URL="postgresql://<username>:<password>@<host>:5432/<database>"

# API server — APP_URL and BETTER_AUTH_URL must match
PORT=4200
APP_URL='http://localhost:4200'
BETTER_AUTH_SECRET=
BETTER_AUTH_URL='http://localhost:4200'

CORS_ORIGINS='http://localhost:4200,http://127.0.0.1:4200,http://localhost:3000,http://localhost:3001'


YOUTUBE_API_KEY=''

# Klariti tag issuance
KTAG_BASE_URL='https://klariti.so'
KTAG_SIG_VERSION=1
# PEM or base64-encoded PEM for the server-side Ed25519 private key
KTAG_SIGNING_PRIVATE_KEY=''
# PEM or base64-encoded PEM for the corresponding Ed25519 public key
KTAG_SIGNING_PUBLIC_KEY=''


