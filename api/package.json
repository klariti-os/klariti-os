{
  "name": "@klariti/api",
  "private": true,
  "type": "module",
  "exports": {
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./contracts": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "scripts": {
    "build:runtime-deps": "pnpm --filter @klariti/database build && pnpm --filter @klariti/url-class build",
    "build": "pnpm run build:runtime-deps && tsc --noEmit",
    "dev": "pnpm run build:runtime-deps && tsx watch --env-file=../.env src/server.ts",
    "check-types": "tsc --noEmit",
    "test": "pnpm run build:runtime-deps && vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^5.2.2",
    "@klariti/database": "workspace:*",
    "@klariti/url-class": "workspace:*",
    "@ts-rest/core": "^3.51.0",
    "@ts-rest/fastify": "^3.52.1",
    "@ts-rest/open-api": "^3.51.0",
    "better-auth": "^1.2.0",
    "fastify": "^5.7.2",
    "fastify-plugin": "^5.0.1",
    "unique-names-generator": "4.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.2.0",
    "dotenv": "^17.2.3",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
